@model List<InternFlow.EL.DBContextModels.Project>

@{
    ViewData["Title"] = "Projeler";
    var filter = ViewBag.CurrentFilter as string;
}

<link rel="stylesheet" href="~/css/project.css" />

<div class="container mt-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="page-title">📁 Projeler</h1>
            <p class="page-subtitle">
                Projeleri filtrele ve yönet
            </p>
        </div>

        <!-- CREATE BUTTON -->
        <button type="button"
                class="btn new-project-btn"
                data-bs-toggle="modal"
                data-bs-target="#createModal">

            + Yeni Proje

        </button>

    </div>

    <!-- FILTERS -->
    <div class="mb-4 d-flex gap-2 flex-wrap">

        <a asp-action="Index"
           class="btn filter-btn @(string.IsNullOrEmpty(filter) ? "active" : "")">

            Hepsi

        </a>

        <a asp-action="Index"
           asp-route-status="Active"
           class="btn filter-btn @(filter == "Active" ? "active" : "")">

            Aktif

        </a>

        <a asp-action="Index"
           asp-route-status="Passive"
           class="btn filter-btn @(filter == "Passive" ? "active" : "")">

            Pasif

        </a>

        <a asp-action="Index"
           asp-route-status="Pending"
           class="btn filter-btn @(filter == "Pending" ? "active" : "")">

            Beklemede

        </a>

    </div>

    <!-- PROJECT LIST -->
    <div class="row g-4">

        @foreach (var item in Model)
        {
            <div class="col-md-4">

                <div class="card project-card h-100">

                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-center">

                            <h4 class="project-title">
                                @item.Name
                            </h4>

                            <span class="status @(item.Status?.ToLower())">

                                @item.Status

                            </span>

                        </div>

                        <hr />

                        <p class="project-desc">

                            @(string.IsNullOrEmpty(item.Description)
                                                    ? "Açıklama bulunmuyor."
                                                    : item.Description)

                    </p>

                    </div>

                    <div class="card-footer project-footer">

                        <!-- EDIT -->
                        <button type="button"
                                class="btn btn-edit"
                                onclick="openEditModal(
                                        '@item.Id',
                                        '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(item.Name ?? ""))',
                                        '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(item.Description ?? ""))',
                                        '@item.Status'
                                    )">

                            Düzenle

                        </button>

                        <!-- DELETE -->
                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-delete">

                            Sil

                        </a>

                    </div>

                </div>

            </div>
                }

    </div>

</div>

<!-- ================================= -->
<!-- CREATE MODAL -->
<!-- ================================= -->

<div class="modal fade"
     id="createModal"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content modal-box">

            <div class="modal-header border-0">

                <h4 class="fw-bold">
                    Yeni Proje
                </h4>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <form asp-action="Create" method="post">

                <div class="modal-body">

                    <!-- NAME -->
                    <div class="mb-3">

                        <label class="form-label">
                            Proje Adı
                        </label>

                        <input type="text"
                               name="Name"
                               class="form-control"
                               required />

                    </div>

                    <!-- DESCRIPTION -->
                    <div class="mb-3">

                        <label class="form-label">
                            Açıklama
                        </label>

                        <textarea name="Description"
                                  rows="4"
                                  class="form-control"></textarea>

                    </div>

                    <!-- STATUS -->
                    <div class="mb-3">

                        <label class="form-label">
                            Durum
                        </label>

                        <select name="Status"
                                class="form-select">

                            <option value="Active">
                                Aktif
                            </option>

                            <option value="Passive">
                                Pasif
                            </option>

                            <option value="Pending">
                                Beklemede
                            </option>

                        </select>

                    </div>

                </div>

                <div class="modal-footer border-0">

                    <button type="button"
                            class="btn btn-light"
                            data-bs-dismiss="modal">

                        Vazgeç

                    </button>

                    <button type="submit"
                            class="btn save-btn">

                        Kaydet

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

<!-- ================================= -->
<!-- EDIT MODAL -->
<!-- ================================= -->

<div class="modal fade"
     id="editModal"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content modal-box">

            <div class="modal-header border-0">

                <h4 class="fw-bold">
                    Projeyi Düzenle
                </h4>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <form asp-action="Edit" method="post">

                <div class="modal-body">

                    <!-- ID -->
                    <input type="hidden"
                           id="editId"
                           name="Id" />

                    <!-- NAME -->
                    <div class="mb-3">

                        <label class="form-label">
                            Proje Adı
                        </label>

                        <input type="text"
                               id="editName"
                               name="Name"
                               class="form-control"
                               required />

                    </div>

                    <!-- DESCRIPTION -->
                    <div class="mb-3">

                        <label class="form-label">
                            Açıklama
                        </label>

                        <textarea id="editDescription"
                                  name="Description"
                                  rows="4"
                                  class="form-control"></textarea>

                    </div>

                    <!-- STATUS -->
                    <div class="mb-3">

                        <label class="form-label">
                            Durum
                        </label>

                        <select id="editStatus"
                                name="Status"
                                class="form-select">

                            <option value="Active">
                                Aktif
                            </option>

                            <option value="Passive">
                                Pasif
                            </option>

                            <option value="Pending">
                                Beklemede
                            </option>

                        </select>

                    </div>

                </div>

                <div class="modal-footer border-0">

                    <button type="button"
                            class="btn btn-light"
                            data-bs-dismiss="modal">

                        Vazgeç

                    </button>

                    <button type="submit"
                            class="btn save-btn">

                        Güncelle

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

<!-- ================================= -->
<!-- BOOTSTRAP JS -->
<!-- ================================= -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<!-- ================================= -->
<!-- JS -->
<!-- ================================= -->

<script>

    function openEditModal(id, name, description, status) {

        document.getElementById("editId").value = id;
        document.getElementById("editName").value = name;
        document.getElementById("editDescription").value = description;
        document.getElementById("editStatus").value = status;

        var modal = new bootstrap.Modal(
            document.getElementById("editModal")
        );

        modal.show();
    }

</script>