@model List<InternFlow.EL.DBContextModels.Project>

@{
    ViewData["Title"] = "Projects";
    var filter = ViewBag.CurrentFilter as string;
}

<link rel="stylesheet" href="~/css/project.css" />

<div class="container mt-5">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="page-title">📁 Projects</h1>
            <p class="page-subtitle">
                Filter and administer projects
            </p>
        </div>

        <!-- Oluşturma Butonu -->
        @if (User.IsInRole("Admin"))
        {
            <button type="button"
                    class="btn new-project-btn"
                    data-bs-toggle="modal"
                    data-bs-target="#createModal">
                + New Project
            </button>
        }

    </div>

    <!-- Arama Kutusu -->
    <div class="mb-4">

        <input type="text"
               id="projectSearch"
               class="form-control"
               placeholder="Search Project..." />

    </div>

    <!-- Filtreleme -->
    <div class="mb-4 d-flex gap-2 flex-wrap">

        <a asp-action="Index"
           class="btn filter-btn @(string.IsNullOrEmpty(filter) ? "active" : "")">

            All

        </a>

        <a asp-action="Index"
           asp-route-status="Active"
           class="btn filter-btn @(filter == "Active" ? "active" : "")">

            Active

        </a>

        <a asp-action="Index"
           asp-route-status="Passive"
           class="btn filter-btn @(filter == "Passive" ? "active" : "")">

            Passive

        </a>

        <a asp-action="Index"
           asp-route-status="Pending"
           class="btn filter-btn @(filter == "Pending" ? "active" : "")">

            Pending

        </a>

    </div>

    <!-- Proje Listesi -->
    <div class="row g-4">

        @foreach (var item in Model)
        {
            <div class="col-md-4 project-item"
                 data-name="@item.Name"
                 data-description="@item.Description"
                 data-status="@item.Status">

                <div class="card project-card h-100">

                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-center">

                            <h4 class="project-title">
                                @item.Name
                            </h4>

                            <span class="status @(item.Status?.ToLower())">

                                @item.Status

                            </span>

                        </div>

                        <hr />

                        <p class="project-desc">

                            @(string.IsNullOrEmpty(item.Description)
                                                    ? "Açıklama bulunmuyor."
                                                    : item.Description)

                    </p>

                    </div>

                    <div class="card-footer project-footer">
                        @if (User.IsInRole("Admin"))
                        {
                            <button type="button"
                                    class="btn btn-edit"
                                    onclick="openEditModal(
                                '@item.Id',
                                '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(item.Name ?? ""))',
                                '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(item.Description ?? ""))',
                                '@item.Status'
                                )">
                                Edit
                            </button>

                            <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-delete"
                                   onclick="return confirm('Are you sure you want to delete this project?');">
                                Delete
                            </a>
                        }
                    </div>

                </div>

            </div>
                }

    </div>

</div>

<!-- Modal Oluştur -->

<div class="modal fade"
     id="createModal"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content modal-box">

            <div class="modal-header border-0">

                <h4 class="fw-bold">
                    Yeni Proje
                </h4>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <form asp-action="Create" method="post">

                <div class="modal-body">

                    <!-- Ad -->
                    <div class="mb-3">

                        <label class="form-label">
                            Proje Adı
                        </label>

                        <input type="text"
                               name="Name"
                               class="form-control"
                               required />

                    </div>

                    <!-- Açıklama -->
                    <div class="mb-3">

                        <label class="form-label">
                            Açıklama
                        </label>

                        <textarea name="Description"
                                  rows="4"
                                  class="form-control"></textarea>

                    </div>

                    <!-- Durum -->
                    <div class="mb-3">

                        <label class="form-label">
                            Durum
                        </label>

                        <select name="Status"
                                class="form-select">

                            <option value="Active">
                                Aktif
                            </option>

                            <option value="Passive">
                                Pasif
                            </option>

                            <option value="Pending">
                                Beklemede
                            </option>

                        </select>

                    </div>

                </div>

                <div class="modal-footer border-0">

                    <button type="button"
                            class="btn btn-light"
                            data-bs-dismiss="modal">

                        Vazgeç

                    </button>

                    <button type="submit"
                            class="btn save-btn">

                        Kaydet

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

<!-- Modal Düzenle -->

<div class="modal fade"
     id="editModal"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content modal-box">

            <div class="modal-header border-0">

                <h4 class="fw-bold">
                    Projeyi Düzenle
                </h4>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <form asp-action="Edit" method="post">

                <div class="modal-body">

                    <!-- Id -->
                    <input type="hidden"
                           id="editId"
                           name="Id" />

                    <!-- Ad -->
                    <div class="mb-3">

                        <label class="form-label">
                            Proje Adı
                        </label>

                        <input type="text"
                               id="editName"
                               name="Name"
                               class="form-control"
                               required />

                    </div>

                    <!-- Açıklama -->
                    <div class="mb-3">

                        <label class="form-label">
                            Açıklama
                        </label>

                        <textarea id="editDescription"
                                  name="Description"
                                  rows="4"
                                  class="form-control"></textarea>

                    </div>

                    <!-- Durum -->
                    <div class="mb-3">

                        <label class="form-label">
                            Durum
                        </label>

                        <select id="editStatus"
                                name="Status"
                                class="form-select">

                            <option value="Active">
                                Aktif
                            </option>

                            <option value="Passive">
                                Pasif
                            </option>

                            <option value="Pending">
                                Beklemede
                            </option>

                        </select>

                    </div>

                </div>

                <div class="modal-footer border-0">

                    <button type="button"
                            class="btn btn-light"
                            data-bs-dismiss="modal">

                        Vazgeç

                    </button>

                    <button type="submit"
                            class="btn save-btn">

                        Güncelle

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>


<script>

    function openEditModal(id, name, description, status) {

        document.getElementById("editId").value = id;
        document.getElementById("editName").value = name;
        document.getElementById("editDescription").value = description;
        document.getElementById("editStatus").value = status;

        var modal = new bootstrap.Modal(
            document.getElementById("editModal")
        );

        modal.show();
    }

        // PROJECT SEARCH

    const projectSearch =
        document.getElementById("projectSearch");

    const projectItems =
        document.querySelectorAll(".project-item");

    projectSearch.addEventListener("input", function () {

        const value =
            this.value.toLowerCase();

        projectItems.forEach(item => {

            const name =
                item.dataset.name?.toLowerCase() || "";

            const description =
                item.dataset.description?.toLowerCase() || "";

            const status =
                item.dataset.status?.toLowerCase() || "";

            if (
                name.includes(value) ||
                description.includes(value) ||
                status.includes(value)
            ) {

                item.style.display = "";

            } else {

                item.style.display = "none";

            }

        });

    });

</script>