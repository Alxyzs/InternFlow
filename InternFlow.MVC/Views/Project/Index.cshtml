@model List<InternFlow.EL.DBContextModels.Project>

@{
    ViewData["Title"] = "Projects";
    var filter = ViewBag.CurrentFilter as string;
}

<link rel="stylesheet" href="~/css/project.css" />

<div class="container mt-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="page-title">📁 Projects</h1>
            <p class="page-subtitle">Filter and administer projects</p>
        </div>

        @if (User.IsInRole("Admin"))
        {
            <button type="button"
                    class="btn new-project-btn"
                    data-bs-toggle="modal"
                    data-bs-target="#createModal">
                + New Project
            </button>
        }

    </div>

    <!-- SEARCH -->
    <div class="mb-4">
        <input type="text"
               id="projectSearch"
               class="form-control"
               placeholder="Search Project..." />
    </div>

    <!-- FILTER -->
    <div class="mb-4 d-flex gap-2 flex-wrap">

        <a asp-action="Index"
           class="btn filter-btn @(string.IsNullOrEmpty(filter) ? "active" : "")">
            All
        </a>

        <a asp-action="Index" asp-route-status="Active"
           class="btn filter-btn @(filter == "Active" ? "active" : "")">
            Active
        </a>

        <a asp-action="Index" asp-route-status="Passive"
           class="btn filter-btn @(filter == "Passive" ? "active" : "")">
            Passive
        </a>

        <a asp-action="Index" asp-route-status="Pending"
           class="btn filter-btn @(filter == "Pending" ? "active" : "")">
            Pending
        </a>

    </div>

    <!-- PROJECT LIST -->
    <div class="row g-4" id="projectContainer">

        @foreach (var item in Model)
        {
            <div class="col-md-4 project-item"
                 data-name="@item.Name"
                 data-description="@item.Description"
                 data-status="@item.Status">

                <div class="card project-card h-100">

                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-center">

                            <h4 class="project-title">
                                @item.Name
                            </h4>

                            <span class="status @(item.Status?.ToLower())">
                                @item.Status
                            </span>

                        </div>

                        <hr />

                        <p class="project-desc">
                            @(string.IsNullOrEmpty(item.Description)
                                                    ? "Açıklama bulunmuyor."
                                                    : item.Description)
                    </p>

                    </div>

                    <div class="card-footer project-footer">

                    @if (User.IsInRole("Admin"))
                        {
                            <button type="button"
                                    class="btn btn-edit"
                                    onclick="openEditModal(
                                                '@item.Id',
                                                '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(item.Name ?? ""))',
                                                '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(item.Description ?? ""))',
                                                '@item.Status'
                                            )">
                                Edit
                            </button>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-delete"
                               onclick="return confirm('Are you sure?');">
                                Delete
                            </a>
                        }

                    </div>

                </div>
            </div>
        }

    </div>

    <!-- PAGINATION -->
    <div id="projectPagination" class="mt-4"></div>

</div>

<!-- CREATE MODAL -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-box">

            <div class="modal-header border-0">
                <h4>Yeni Proje</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form asp-action="Create" method="post">

                <div class="modal-body">

                    <input type="text" name="Name" class="form-control mb-2" placeholder="Project Name" required />

                    <textarea name="Description" class="form-control mb-2" placeholder="Description"></textarea>

                    <select name="Status" class="form-select">
                        <option value="Active">Active</option>
                        <option value="Passive">Passive</option>
                        <option value="Pending">Pending</option>
                    </select>

                </div>

                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save</button>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-box">

            <form asp-action="Edit" method="post">

                <div class="modal-body">

                    <input type="hidden" id="editId" name="Id" />

                    <input type="text" id="editName" name="Name" class="form-control mb-2" />

                    <textarea id="editDescription" name="Description" class="form-control mb-2"></textarea>

                    <select id="editStatus" name="Status" class="form-select">
                        <option value="Active">Active</option>
                        <option value="Passive">Passive</option>
                        <option value="Pending">Pending</option>
                    </select>

                </div>

                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update</button>
                </div>

            </form>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>

    // EDIT MODAL
    function openEditModal(id, name, description, status) {
        document.getElementById("editId").value = id;
        document.getElementById("editName").value = name;
        document.getElementById("editDescription").value = description;
        document.getElementById("editStatus").value = status;

        new bootstrap.Modal(document.getElementById("editModal")).show();
    }

    // DATA
    const items = Array.from(document.querySelectorAll(".project-item"));
    const searchInput = document.getElementById("projectSearch");

    let currentPage = 1;
    const itemsPerPage = 6;
    let filteredItems = [...items];

    // RENDER
    function render() {

        const start = (currentPage - 1) * itemsPerPage;
        const end = start + itemsPerPage;

        items.forEach(i => i.style.display = "none");

        filteredItems.slice(start, end).forEach(i => i.style.display = "");

        renderPagination();
    }

    // PAGINATION
    function renderPagination() {

        const totalPages = Math.ceil(filteredItems.length / itemsPerPage);

        let html = `<ul class="pagination justify-content-center">`;

        html += `
            <li class="page-item ${currentPage === 1 ? "disabled" : ""}">
                <a class="page-link" href="#" onclick="changePage(${currentPage - 1})">Prev</a>
            </li>
        `;

        for (let i = 1; i <= totalPages; i++) {

            html += `
                <li class="page-item ${i === currentPage ? "active" : ""}">
                    <a class="page-link" href="#" onclick="changePage(${i})">${i}</a>
                </li>
            `;
        }

        html += `
            <li class="page-item ${currentPage === totalPages ? "disabled" : ""}">
                <a class="page-link" href="#" onclick="changePage(${currentPage + 1})">Next</a>
            </li>
        `;

        html += `</ul>`;

        document.getElementById("projectPagination").innerHTML = html;
    }

    // PAGE CHANGE
    function changePage(page) {

        const totalPages = Math.ceil(filteredItems.length / itemsPerPage);

        if (page < 1 || page > totalPages) return;

        currentPage = page;
        render();
    }

    // GLOBAL SEARCH
    searchInput.addEventListener("input", function () {

        const value = this.value.toLowerCase();

        filteredItems = items.filter(item => {

            const name = item.dataset.name.toLowerCase();
            const desc = item.dataset.description.toLowerCase();
            const status = item.dataset.status.toLowerCase();

            return name.includes(value) ||
                   desc.includes(value) ||
                   status.includes(value);
        });

        currentPage = 1;
        render();
    });

    // INIT
    render();

</script>