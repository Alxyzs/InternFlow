
@{
}
@model List<InternFlow.EL.DBContextModels.User>

@{
    ViewData["Title"] = "Kullanıcılar";
}

<link rel="stylesheet" href="~/css/user.css" />

<div class="container mt-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="user-title">
                👥 Users
            </h1>

            <p class="user-subtitle">
                Manage users in the system
            </p>

        </div>

        <a asp-action="Create"
           class="btn save-btn">

            + New User

        </a>

    </div>

    <!-- SEARCH BOX -->
    <div class="mb-4">

        <input type="text"
               id="userSearch"
               class="form-control"
               placeholder="Search user..." />

    </div>

    <!-- USER LIST -->
    <div class="row g-4">

        @foreach (var item in Model)
        {
            <div class="col-md-4">

                <div class="card user-list-card h-100">

                    <div class="card-body">

                        <h4 class="fw-bold mb-3">
                            @item.FullName
                        </h4>

                        <p class="text-muted mb-2">
                            📧 @item.Email
                        </p>

                        <p class="text-muted">
                            📅 @item.CreatedAt.ToShortDateString()
                        </p>

                    </div>

                    <div class="card-footer bg-white border-0 d-flex gap-2">

                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-edit w-50">

                            Edit

                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-delete"
                           onclick="return confirm('Are you sure you want to delete this user?');">

                            Delete

                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>

<script>

    const searchInput =
        document.getElementById("userSearch");

    const userCards =
        document.querySelectorAll(".user-list-card");

    searchInput.addEventListener("input", function () {

        const value =
            this.value.toLowerCase();

        userCards.forEach(card => {

            const name =
                card.querySelector("h4")?.innerText.toLowerCase() || "";

            const email =
                card.querySelectorAll("p")[0]?.innerText.toLowerCase() || "";

            if (name.includes(value) || email.includes(value)) {

                card.parentElement.style.display = "";

            } else {

                card.parentElement.style.display = "none";

            }

        });

    });

</script>