@{
}
@model InternFlow.EL.DBContextModels.User

@{
    ViewData["Title"] = "Yeni Kullanıcı";
}

<link rel="stylesheet" href="~/css/user.css" />

<div class="container mt-5">

    <div class="user-card mx-auto">

        <div class="text-center mb-4">

            <h1 class="user-title">
                👤 Yeni Kullanıcı
            </h1>

            <p class="user-subtitle">
                Sisteme yeni kullanıcı ekle
            </p>

        </div>

        <form asp-action="Create" method="post">

            <!-- FULL NAME -->
            <div class="mb-4">

                <label class="form-label">
                    Ad Soyad
                </label>

                <input asp-for="FullName"
                       class="form-control custom-input"
                       required />

            </div>

            <!-- EMAIL -->
            <div class="mb-4">

                <label class="form-label">
                    Email
                </label>

                <input asp-for="Email"
                       class="form-control custom-input"
                       required />

            </div>

            <div class="d-flex gap-3 mt-4">

                <a asp-action="Index"
                   class="btn back-btn w-50">

                    Geri Dön

                </a>

                <button type="submit"
                        class="btn save-btn w-50">

                    Kullanıcı Oluştur

                </button>

            </div>

        </form>

    </div>

</div>