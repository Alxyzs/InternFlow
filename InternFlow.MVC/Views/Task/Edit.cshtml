@model InternFlow.EL.DBContextModels.TaskItem
@using InternFlow.BLL.Interfaces

@inject IUserService userService

@{
    var users = userService.GetAll();
}

<div class="container mt-5">

    <div class="card p-4 mx-auto" style="max-width:650px;">

        <h3>✏️ Edit Task</h3>

        <form asp-action="Edit" method="post">

            <!-- Gorev id -->
            <input type="hidden" asp-for="Id" />

            <!-- Proje Id -->
            <input type="hidden" asp-for="ProjectId" />

            <!-- Baslik -->
            <div class="mb-3">
                <label>Title</label>
                <input asp-for="Title" class="form-control" />
            </div>

            <!-- Açıklama -->
            <div class="mb-3">
                <label>Description</label>
                <textarea asp-for="Description" class="form-control"></textarea>
            </div>

            <!-- Durum -->
            <div class="mb-3">
                <label>Status</label>

                <select asp-for="Status" class="form-select">
                    <option value="Active">Active</option>
                    <option value="Passive">Passive</option>
                    <option value="Pending">Pending</option>
                </select>
            </div>

            <!-- Oncelik -->
            <div class="mb-3">
                <label>Priority</label>

                <select asp-for="Priority" class="form-select">
                    <option value="Low">Low</option>
                    <option value="Normal">Normal</option>
                    <option value="High">High</option>
                </select>
            </div>

            <!-- Kullanici Arama -->
            <div class="mb-3">

                <label>User</label>

                <input type="text"
                       id="userSearch"
                       class="form-control mb-1"
                       placeholder="Seach User..." />

                <select asp-for="AssignedUserId"
                        id="userSelect"
                        class="form-select">

                    <option value="">-- Seç --</option>

                    @foreach (var u in users)
                    {
                        <option value="@u.Id"
                                selected="@(u.Id == Model.AssignedUserId)">

                            @u.FullName

                        </option>
                    }

                </select>

            </div>

            <!-- Tarih -->
            <div class="mb-3">

                <label>Due Date</label>

                <input asp-for="DueDate"
                       type="date"
                       class="form-control" />

            </div>

            <button type="submit"
                    class="btn btn-success w-100">

                Update

            </button>

        </form>

    </div>

</div>

<script>

    function filterSelect(inputId, selectId) {

        const input = document.getElementById(inputId);
        const select = document.getElementById(selectId);

        input.addEventListener("input", function () {

            const value = this.value.toLowerCase();

            for (let i = 0; i < select.options.length; i++) {

                const text = select.options[i].text.toLowerCase();

                select.options[i].hidden =
                    !text.includes(value);

            }

        });
    }

    filterSelect("userSearch", "userSelect");

</script>