@model List<InternFlow.EL.DBContextModels.TaskItem>

@using InternFlow.BLL.Interfaces
@inject IUserService userService
@inject IProjectService projectService

@using System.Security.Claims
@{
    var users = userService.GetAll();
    var projects = projectService.GetAll();
    var currentUserId = int.Parse(User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "0");
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2> Tasks</h2>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#otherTasksModal">
                Other Tasks
            </button>
            <a asp-action="Create" class="btn btn-success">+ New Task</a>
        </div>
    </div>

    <div class="mb-4">
        <input type="text" id="taskSearch" class="form-control" placeholder="Search task..." />
    </div>

    <!-- MY TASKS -->
    <div id="myTasksSection">
        <h4 class="mb-3"> My Tasks</h4>
        <div class="row g-4" id="myTaskContainer"></div>
        <div id="noMyTasks" class="alert alert-info text-center mb-4" style="display:none;">
            You have no tasks assigned to you.
        </div>
        <div id="pagination" class="mt-4"></div>
    </div>

    <!-- OTHER TASKS MODAL -->
    <div class="modal fade" id="otherTasksModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"> Other Tasks</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-4" id="otherTaskContainer"></div>
                    <div id="noOtherTasks" class="alert alert-secondary text-center" style="display:none;">
                        No other tasks found.
                    </div>
                    <div class="text-center mt-3" id="loadMoreContainer" style="display:none;">
                        <button class="btn btn-outline-primary" onclick="loadMore()">Load More</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Kartlar burada render edilir, JS ile taşınır -->
    <div style="display:none" id="taskContainer">
        @foreach (var item in Model)
        {
            var project = projects.FirstOrDefault(x => x.Id == item.ProjectId);
            var user = users.FirstOrDefault(x => x.Id == item.AssignedUserId);
            var isMyTask = item.AssignedUserId == currentUserId;

            <div class="col-md-4 task-card"
                 data-title="@item.Title"
                 data-description="@item.Description"
                 data-id="@item.Id"
                 data-status="@item.Status"
                 data-mine="@isMyTask.ToString().ToLower()">

                <div class="card shadow-sm p-3 h-100 @(isMyTask ? "border-primary" : "")">

                    @if (isMyTask)
                    {
                        <span class="badge bg-primary mb-2" style="width:fit-content;">My Task</span>
                    }

                    <h5>@item.Title</h5>

                    <p class="text-muted">
                        @(string.IsNullOrEmpty(item.Description) ? "No Description" : item.Description)
                    </p>

                    <hr />

                    <div>📁 <b>Project:</b> @(project?.Name ?? "Not Assigned")</div>

                    @{
                        var taskAssignees = ViewBag.TaskAssignees as List<InternFlow.EL.DBContextModels.TaskAssignee>;
                        var assigneeNames = taskAssignees?.Where(ta => ta.TaskItemId == item.Id)
                            .Select(ta => users.FirstOrDefault(u => u.Id == ta.UserId)?.FullName ?? "")
                            .Where(n => !string.IsNullOrEmpty(n)).ToList();
                    }
                    <div>
                        👤 <b>Users:</b>
                        @if (assigneeNames != null && assigneeNames.Any())
                        {
                            @string.Join(", ", assigneeNames)
                        }
                        else
                        {
                            <span>@(user?.FullName ?? "Not Assigned")</span>
                        }
                    </div>

                    <div class="mt-2">
                        <span class="badge bg-secondary status-badge">@item.Status</span>
                        <span class="badge bg-info">@item.Priority</span>
                    </div>

                    <div class="mt-3 d-flex gap-2">

                        @if (User.IsInRole("Admin") || item.AssignedUserId == currentUserId)
                        {
                            <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-primary w-100">
                                Edit
                            </a>
                        }

                        <a asp-action="Detail"
                               asp-route-id="@item.Id"
                               class="btn btn-dark w-100">
                            Details
                        </a>

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger w-100"
                                   onclick="return confirm('Delete task?');">
                                Delete
                            </a>
                        }

                        @if (User.IsInRole("Admin") || item.AssignedUserId == currentUserId)
                        {
                            <div class="complete-btn-area w-100">
                                @if (item.Status != "Completed")
                                {
                                    <form asp-action="UpdateStatus" method="post" class="w-100">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="status" value="Completed" />
                                        <button type="submit" class="btn btn-success w-100">Complete</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="btn btn-success w-100 disabled">Completed</span>
                                }
                            </div>
                        }

                    </div>

                    <div class="mt-2">
                        📅 <b>Due Date:</b>
                        @if (item.DueDate.HasValue)
                        {
                            if (item.DueDate.Value.Date < DateTime.Now.Date)
                            {
                                <span class="text-danger fw-bold">Expired</span>
                            }
                            else
                            {
                                @item.DueDate.Value.ToString("dd.MM.yyyy")
                            }
                        }
                        else
                        {
                            <span>Uncertain</span>
                        }
                    </div>

                </div>
            </div>
        }
    </div>

</div>

<script>
    const allCards = Array.from(document.querySelectorAll(".task-card"));
    const myContainer = document.getElementById("myTaskContainer");
    const otherContainer = document.getElementById("otherTaskContainer");
    const noMyTasks = document.getElementById("noMyTasks");
    const noOtherTasks = document.getElementById("noOtherTasks");
    const searchInput = document.getElementById("taskSearch");

    const myCards = allCards.filter(c => c.dataset.mine === "true");
    const otherCards = allCards.filter(c => c.dataset.mine === "false");

    // My Tasks kartlarını taşı
    myCards.forEach(c => {c.style.display = "none";myContainer.appendChild(c);});

    // Other Tasks kartlarını taşı ama gizle
    otherCards.forEach(c => {c.style.display = "none";otherContainer.appendChild(c);});

    if (myCards.length === 0) noMyTasks.style.display = "";
    if (otherCards.length === 0) noOtherTasks.style.display = "";

    // My Tasks pagination
    const myItemsPerPage = 10;
    let myCurrentPage = 1;

    function renderMyTasks() {
        const start = (myCurrentPage - 1) * myItemsPerPage;
        const end = start + myItemsPerPage;
        myCards.forEach(c => c.style.display = "none");
        myCards.slice(start, end).forEach(c => c.style.display = "");
        renderMyPagination();
    }

    function renderMyPagination() {
        const totalPages = Math.ceil(myCards.length / myItemsPerPage);
        if (totalPages <= 1) {
            document.getElementById("pagination").innerHTML = "";
            return;
        }
        let html = `<ul class="pagination justify-content-center">`;
        html += `<li class="page-item ${myCurrentPage === 1 ? "disabled" : ""}">
            <a class="page-link" href="#" onclick="changeMyPage(${myCurrentPage - 1})">Prev</a></li>`;
        for (let i = 1; i <= totalPages; i++) {
            html += `<li class="page-item ${i === myCurrentPage ? "active" : ""}">
                <a class="page-link" href="#" onclick="changeMyPage(${i})">${i}</a></li>`;
        }
        html += `<li class="page-item ${myCurrentPage === totalPages ? "disabled" : ""}">
            <a class="page-link" href="#" onclick="changeMyPage(${myCurrentPage + 1})">Next</a></li>`;
        html += `</ul>`;
        document.getElementById("pagination").innerHTML = html;
    }

    function changeMyPage(page) {
        const totalPages = Math.ceil(myCards.length / myItemsPerPage);
        if (page < 1 || page > totalPages) return;
        myCurrentPage = page;
        renderMyTasks();
    }

    renderMyTasks();

    // Other Tasks Load More
    const otherItemsPerPage = 10;
    let currentCount = 0;

    function loadMore() {
        const end = currentCount + otherItemsPerPage;
        otherCards.slice(currentCount, end).forEach(c => c.style.display = "");
        currentCount = end;
        document.getElementById("loadMoreContainer").style.display = currentCount < otherCards.length ? "" : "none";
    }

    // Modal açılınca ilk 10u göstermesi icin
    document.getElementById("otherTasksModal").addEventListener("show.bs.modal", function () {
        currentCount = 0;
        otherCards.forEach(c => c.style.display = "none");
        loadMore();
    });

    // Search sadece My Tasksta ara
    searchInput.addEventListener("input", function () {
        const value = this.value.toLowerCase();
        myCards.forEach(card => {
            const title = card.dataset.title.toLowerCase();
            const desc = card.dataset.description.toLowerCase();
            card.style.display = (title.includes(value) || desc.includes(value)) ? "" : "none";
        });
    });
</script>