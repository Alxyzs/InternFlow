@model List<InternFlow.EL.DBContextModels.TaskItem>

@using InternFlow.BLL.Interfaces
@inject IUserService userService
@inject IProjectService projectService

@{
    var users = userService.GetAll();
    var projects = projectService.GetAll();
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>📌 Tasks </h2>

        <a asp-action="Create" class="btn btn-success">
            + New Task
        </a>

    </div>

    <!-- Arama Kutusu -->
    <div class="mb-4">

        <input type="text"
               id="taskSearch"
               class="form-control"
               placeholder="Search task..." />

    </div>

    <div class="row g-4">

        @foreach (var item in Model)
        {
            var project = projects.FirstOrDefault(x => x.Id == item.ProjectId);
            var user = users.FirstOrDefault(x => x.Id == item.AssignedUserId);

            <div class="col-md-4 task-card"
                 data-title="@item.Title"
                 data-description="@item.Description">

                <div class="card shadow-sm p-3 h-100">

                    <!-- Baslik -->
                    <h5 class="mb-2">
                        @item.Title
                    </h5>

                    <!-- Aciklama -->
                    <p class="text-muted">
                        @(string.IsNullOrEmpty(item.Description)
                                            ? "No Description"
                                            : item.Description)
                </p>

                    <hr />

                    <!-- Proje -->
                    <div class="mb-1">
                        📁 <b>Project:</b>
                        @(project?.Name ?? "Not Appointed")
                    </div>

                    <!-- Kullanici -->
                    <div class="mb-1">
                        👤 <b>User:</b>
                        @(user?.FullName ?? "Not Appointed")
                    </div>

                    <!-- Durum -->
                    <div class="mt-2">
                        <span class="badge bg-secondary">
                            @item.Status
                        </span>

                        <span class="badge bg-info">
                            @item.Priority
                        </span>
                    </div>

                    <!-- Eylemler -->
                    <div class="mt-3 d-flex gap-2">

                        @if (User.IsInRole("Admin"))
                        {
                            <!-- EDIT -->
                            <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-primary w-100">
                                Edit
                            </a>
                        }

                        <!-- Detaylar -->
                        <a asp-action="Detail"
                               asp-route-id="@item.Id"
                               class="btn btn-dark w-100">
                            Details
                        </a>

                        @if (User.IsInRole("Admin"))
                        {
                            <!-- Sil -->
                            <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger w-100"
                                   onclick="return confirm('Are you sure you want to delete this task?');">
                                Delete
                            </a>
                        }

                        <!-- Tamamlandi -->
                        @if (User.IsInRole("Admin"))
                        {
                            @if (item.Status != "Done")
                            {
                                <form asp-action="UpdateStatus" method="post" class="w-100">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="status" value="Done" />
                                    <button type="submit" class="btn btn-success w-100">
                                        Complete
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="btn btn-success w-100 disabled">
                                    Completed
                                </span>
                            }
                        }

                    </div>

                    <div class="mt-2">

                        📅 <b>Due Date:</b>

                    @if (item.DueDate.HasValue)
                        {
                            if (item.DueDate.Value.Date < DateTime.Now.Date)
                            {
                                <span class="text-danger fw-bold">
                                    Expired
                                </span>
                            }
                            else
                            {
                                @item.DueDate.Value.ToString("dd.MM.yyyy")
                            }
                            }
                            else
                            {
                                <span>Uncertain</span>
                            }

                    </div>

                </div>


            </div>
          }
    </div>

</div>

<script>

    const searchInput =
        document.getElementById("taskSearch");

    const cards =
        document.querySelectorAll(".task-card");

    searchInput.addEventListener("input", function () {

        const value =
            this.value.toLowerCase();

        cards.forEach(card => {

            const title =
                card.dataset.title?.toLowerCase() || "";

            const description =
                card.dataset.description?.toLowerCase() || "";

            if (title.includes(value) ||
                description.includes(value)) {

                card.style.display = "";

            } else {

                card.style.display = "none";

            }

        });

    });

</script>