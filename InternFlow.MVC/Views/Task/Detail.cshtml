@model InternFlow.EL.DBContextModels.TaskItem
@using System.Security.Claims
@{
    var currentUserId = int.Parse(User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "0");
}

<div class="container mt-5">

    <div class="card p-4">

        <!-- Başlık -->
        <h3>@Model.Title</h3>

        <!-- Açıklama -->
        <p class="text-muted">
            @(string.IsNullOrEmpty(Model.Description)
                        ? "Not Appointed"
                        : Model.Description)
        </p>

        <!-- Rozetler -->
        <div class="mb-3">

            <span class="badge bg-secondary">
                @Model.Status
            </span>

            <span class="badge bg-info">
                @Model.Priority
            </span>

        </div>

        <hr />

        <!-- Iliskiler -->
        <div class="mb-2">
            📁 <b>Project:</b> @(Model.Project?.Name ?? "Not Appointed")
        </div>

        <div class="mb-2">
            👤 <b>User:</b> @(Model.AssignedUser?.FullName ?? "Not Appointed")
        </div>

        <!-- Bitiş Tarihi -->
        <div class="mb-2">
            📅 <b>Due Date:</b>
            @(Model.DueDate.HasValue
                        ? Model.DueDate.Value.ToString("dd.MM.yyyy")
                        : "Uncertain")
        </div>

        <!-- Oluşturulma Tarihi -->
        <div class="mb-2 text-muted">
            🕒 Creation Date: @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")
        </div>

    </div>

    <!-- Yorum -->
    <div class="card p-4 mt-3">

        <h5>💬 Comments</h5>

        @if (ViewBag.Comments != null && ViewBag.Comments.Count > 0)
        {
            @foreach (var comment in ViewBag.Comments)
            {
                var commentUser = ((List<InternFlow.EL.DBContextModels.User>)ViewBag.Users).FirstOrDefault(u => u.Id == comment.UserId);

                <div class="border-bottom py-2 d-flex justify-content-between align-items-center">
                    <div>
                        @{
                            var projectMembers = ViewBag.ProjectMembers as List<InternFlow.EL.DBContextModels.ProjectMember>;
                            var isMember = projectMembers?.Any(pm => pm.UserId == comment.UserId) ?? false;
                        }

                        <span class="fw-bold text-primary">👤 @(commentUser?.FullName ?? "Unknown")</span>
                        <span class="badge @(isMember ? "bg-danger" : "bg-secondary") ms-1">
                            @(isMember ? "ProjectMember" : "Misafir")
                        </span>

                        <span class="text-muted ms-2" style="font-size:12px;">@comment.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                        <p class="mb-0 mt-1">@comment.Content</p>
                    </div>
                     @if (User.IsInRole("Admin") || comment.UserId == currentUserId)
                     {
                         <a asp-controller="TaskComment"
                            asp-action="Delete"
                            asp-route-id="@comment.Id"
                            asp-route-taskItemId="@Model.Id"
                            class="btn btn-sm btn-danger">
                             Delete
                         </a>
                     }
                </div>
            }
        }
        else
        {
            <p class="text-muted">No comments yet.</p>
        }

        <form asp-controller="TaskComment" asp-action="Add" method="post" class="mt-3">
            <input type="hidden" name="TaskItemId" value="@Model.Id" />
            <input type="hidden" name="UserId" value="@currentUserId" />
            <textarea name="Content"
                      class="form-control"
                      placeholder="Add a comment..."
                      required></textarea>
            <button class="btn btn-primary mt-2">Send</button>
        </form>

    </div>

</div>