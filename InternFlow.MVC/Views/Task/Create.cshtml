@model InternFlow.EL.DBContextModels.TaskItem
@using InternFlow.BLL.Interfaces

@inject IUserService userService
@inject IProjectService projectService

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@{
    var users = userService.GetAll();
    var projects = projectService.GetAll();
}

@if (TempData["Error"] != null)
{
    <script>
        Swal.fire({
            icon: 'error',
            title: 'Hata',
            text: '@TempData["Error"]',
            confirmButtonColor: '#dc2626'
        });
    </script>
}

<div class="container mt-5">

    <div class="card p-4 mx-auto" style="max-width:650px;">

        <h3>➕ Create Task</h3>

        <form asp-action="Create" method="post" id="taskForm">

            <!-- Title -->
            <div class="mb-3">
                <label>Title</label>
                <input asp-for="Title" id="title" class="form-control" />
            </div>

            <!-- Description -->
            <div class="mb-3">
                <label>Description</label>
                <textarea asp-for="Description" id="desc" class="form-control"></textarea>
            </div>

            <!-- Status -->
            <div class="mb-3">
                <label>Status</label>
                <select asp-for="Status" class="form-select">
                    <option>Active</option>
                    <option>Passive</option>
                    <option>Pending</option>
                </select>
            </div>

            <!-- Priority -->
            <div class="mb-3">
                <label>Priority</label>
                <select asp-for="Priority" class="form-select">
                    <option>Low</option>
                    <option>Normal</option>
                    <option>High</option>
                </select>
            </div>

            <!-- Project -->
            <div class="mb-3">
                <label>Project</label>

                <input type="text"
                       id="projectSearch"
                       class="form-control mb-1"
                       placeholder="Proje ara..." />

                <select asp-for="ProjectId" id="projectSelect" class="form-select">
                    <option value="">-- Select --</option>

                    @foreach (var p in projects)
                    {
                        <option value="@p.Id">@p.Name</option>
                    }
                </select>
            </div>

            <!-- User -->
            <div class="mb-3">
                <label>User</label>

                <input type="text"
                       id="userSearch"
                       class="form-control mb-1"
                       placeholder="Search User..." />

                <select asp-for="AssignedUserId" id="userSelect" class="form-select">
                    <option value="">-- Select --</option>

                    @foreach (var u in users)
                    {
                        <option value="@u.Id">@u.FullName</option>
                    }
                </select>
            </div>

            <!-- Due Date -->
            <div class="mb-3">
                <label>Due Date</label>
                <input asp-for="DueDate" type="date" class="form-control" />
            </div>

            <button type="submit" class="btn btn-success w-100">
                Save
            </button>

        </form>

    </div>

</div>

<script>

    document.getElementById("taskForm").addEventListener("submit", function (e) {

        const title = document.getElementById("title").value.trim();
        const desc = document.getElementById("desc").value.trim();

        if (!title || !desc) {
            e.preventDefault();

            Swal.fire({
                icon: 'warning',
                title: 'Cannot be sent blank',
                text: 'Please fill in all fields.',
                confirmButtonColor: '#f59e0b'
            });
        }
    });

</script>

<!-- =========================
     SEARCH FILTER
========================= -->

<script>

    function filterSelect(inputId, selectId) {

        const input = document.getElementById(inputId);
        const select = document.getElementById(selectId);

        input.addEventListener("input", function () {

            const value = this.value.toLowerCase();

            for (let i = 0; i < select.options.length; i++) {
                const text = select.options[i].text.toLowerCase();
                select.options[i].hidden = !text.includes(value);
            }

        });
    }

    filterSelect("projectSearch", "projectSelect");
    filterSelect("userSearch", "userSelect");

</script>