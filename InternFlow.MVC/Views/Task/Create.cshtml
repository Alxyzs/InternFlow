@model InternFlow.EL.DBContextModels.TaskItem
@using InternFlow.BLL.Interfaces

@inject IUserService userService
@inject IProjectService projectService

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@{
    var users = userService.GetAll();
    var projects = projectService.GetAll();
}

@if (TempData["Error"] != null)
{
    <script>
        Swal.fire({
            icon: 'error',
            title: 'Hata',
            text: '@TempData["Error"]',
            confirmButtonColor: '#dc2626'
        });
    </script>
}

<div class="container mt-5">

    <div class="card p-4 mx-auto" style="max-width:650px;">

        <h3>➕ Create Task</h3>

        <form asp-action="Create" method="post" id="taskForm">

            <!-- Title -->
            <div class="mb-3">
                <label>Title</label>
                <input asp-for="Title" id="title" class="form-control" />
            </div>

            <!-- Description -->
            <div class="mb-3">
                <label>Description</label>
                <textarea asp-for="Description" id="desc" class="form-control"></textarea>
            </div>

            <!-- Status -->
            <div class="mb-3">
                <label>Status</label>
                <select asp-for="Status" class="form-select">
                    <option>Active</option>
                    <option>Passive</option>
                    <option>Pending</option>
                </select>
            </div>

            <!-- Priority -->
            <div class="mb-3">
                <label>Priority</label>
                <select asp-for="Priority" class="form-select">
                    <option>Low</option>
                    <option>Normal</option>
                    <option>High</option>
                </select>
            </div>

            <!-- Project -->
            <div class="mb-3">
                <label>Project</label>

                <input type="text"
                       id="projectSearch"
                       class="form-control mb-1"
                       placeholder="Proje ara..." />

                <select asp-for="ProjectId" id="projectSelect" class="form-select">
                    <option value="">-- Select --</option>

                    @foreach (var p in projects)
                    {
                        <option value="@p.Id">@p.Name</option>
                    }
                </select>
            </div>

            <!-- User -->
            <div class="mb-3">
                <label>Users</label>

                <div class="d-flex gap-2 mb-2">
                    <input type="text"
                           id="userSearch"
                           class="form-control"
                           placeholder="Search User..." />
                    <button type="button"
                            class="btn btn-outline-primary"
                            onclick="addUser()">
                        + Add
                    </button>
                </div>

                <select id="userSelect" class="form-select mb-2">
                    <option value="">-- Select User --</option>
                    @foreach (var u in users)
                    {
                        <option value="@u.Id" data-name="@u.FullName">@u.FullName</option>
                    }
                </select>

                <!-- Seçilen kullanıcılar -->
                <div id="selectedUsers" class="d-flex flex-wrap gap-2 mt-2"></div>

                <!-- İlk kullanıcı AssignedUserId olarak gidecek -->
                <input type="hidden" id="firstUserId" name="AssignedUserId" value="" />

                <!-- Ek kullanıcılar additionalUserIds olarak gidecek -->
                <div id="hiddenUserInputs"></div>
            </div>

            <!-- Due Date -->
            <div class="mb-3">
                <label>Due Date</label>
                <input asp-for="DueDate" type="date" class="form-control" />
            </div>

            <button type="submit" class="btn btn-success w-100">
                Save
            </button>

        </form>

    </div>

</div>

<script>

    document.getElementById("taskForm").addEventListener("submit", function (e) {

        const title = document.getElementById("title").value.trim();
        const desc = document.getElementById("desc").value.trim();

        if (!title || !desc) {
            e.preventDefault();

            Swal.fire({
                icon: 'warning',
                title: 'Cannot be sent blank',
                text: 'Please fill in all fields.',
                confirmButtonColor: '#f59e0b'
            });
        }
    });

</script>

<!-- =========================
     SEARCH FILTER
========================= -->

<script>

    let isFirstUser = true;

    function addUser() {
    const select = document.getElementById("userSelect");
    const selectedId = select.value;
    const selectedName = select.options[select.selectedIndex]?.dataset.name;

    if (!selectedId) return;

    // Aynı kullanıcı iki kez eklenmesin
    const existing = document.querySelector(`#hiddenUserInputs input[value="${selectedId}"]`);
    const firstUserId = document.getElementById("firstUserId").value;
    if (existing || firstUserId === selectedId) {
    Swal.fire({
    icon: 'warning',
    title: 'Already Added',
    text: `${selectedName} is already in the list.`,
    confirmButtonColor: '#f59e0b'
    });
    return;
    }

    // Badge olarak göster
    const badge = document.createElement("span");
    badge.className = "badge bg-primary d-flex align-items-center gap-1 p-2";
    badge.innerHTML = `${selectedName} <button type="button" class="btn-close btn-close-white btn-sm" onclick="removeUser(this, '${selectedId}')"></button>`;
    document.getElementById("selectedUsers").appendChild(badge);

    if (isFirstUser) {
    // İlk kullanıcı AssignedUserId'ye git
    document.getElementById("firstUserId").value = selectedId;
    isFirstUser = false;
    } else {
    // Diğerleri additionalUserIds'e git
    const input = document.createElement("input");
    input.type = "hidden";
    input.name = "additionalUserIds";
    input.value = selectedId;
    input.id = `user_${selectedId}`;
    document.getElementById("hiddenUserInputs").appendChild(input);
    }

    select.value = "";
    }

    function removeUser(btn, userId) {
    btn.closest("span").remove();

    const firstUserId = document.getElementById("firstUserId").value;
    if (firstUserId === userId) {
    document.getElementById("firstUserId").value = "";
    isFirstUser = true;
    } else {
    const input = document.getElementById(`user_${userId}`);
    if (input) input.remove();
    }
    }

    function filterSelect(inputId, selectId) {

        const input = document.getElementById(inputId);
        const select = document.getElementById(selectId);

        input.addEventListener("input", function () {

            const value = this.value.toLowerCase();

            for (let i = 0; i < select.options.length; i++) {
                const text = select.options[i].text.toLowerCase();
                select.options[i].hidden = !text.includes(value);
            }

        });
    }

    filterSelect("projectSearch", "projectSelect");
    filterSelect("userSearch", "userSelect");

</script>