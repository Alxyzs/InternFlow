<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InternFlow.MVC</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InternFlow.MVC.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">🚀 InternFlow</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">🏠 Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Project" asp-action="Index">📁 Projects</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Task" asp-action="Index">📌 Tasks</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Task" asp-action="Kanban">📋 Kanban</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="User" asp-action="Index">👥 Users</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="ActivityLog" asp-action="Index">📜 Activity Logs</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-dark fw-bold">
                                    👤 @User.Identity.Name
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <span class="badge bg-danger ms-1">Admin</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary ms-1">@(User.IsInRole("User") ? "User" : "Stajyer")</span>
                                    }
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">🚪 Logout</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Profile">⚙️ Settings</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - InternFlow.MVC - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

    <script>
        toastr.options = {
        closeButton: true,
        progressBar: true,
        newestOnTop: true,
        preventDuplicates: true,
        positionClass: "toast-top-right",
        timeOut: "3000",
        showMethod: "fadeIn",
        hideMethod: "fadeOut"
        };

        @if (TempData["Success"] != null)
        {
            <text>toastr.success("@TempData["Success"]", "Success"); </text>
        }
        @if (TempData["Error"] != null)
        {
            <text>toastr.error("@TempData["Error"]", "Error"); </text>
        }
        @if (TempData["Warning"] != null)
        {
            <text>toastr.warning("@TempData["Warning"]", "Warning"); </text>
        }
        @if (TempData["Info"] != null)
        {
            <text>toastr.info("@TempData["Info"]", "Info"); </text>
        }
    </script>

    <script>
        const connection = new signalR.HubConnectionBuilder()
        .withUrl("/notificationHub")
        .build();

        connection.on("ReceiveStatusUpdate", function(taskId, newStatus, taskTitle) {
        toastr.info(`"${taskTitle}" status changed to ${newStatus}`, "Task Update");
        });

        connection.on("ReceiveComment", function(taskId, comment) {
        toastr.success(comment, "New Comment");
        });

        connection.on("ReceiveProjectNotification", function(projectName) {
        toastr.info(`"${projectName}" created`, "Project Notification");
        });

        connection.start().catch(err => console.error(err));
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>