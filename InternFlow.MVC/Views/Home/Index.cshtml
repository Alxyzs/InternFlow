@{
    ViewData["Title"] = "Dashboard";
}

<style>

    body {
        background-color: #f4f7fa;
    }

    .dashboard-card {
        transition: all 0.3s ease;
    }

        .dashboard-card:hover {
            transform: translateY(-8px);
        }

    .dashboard-icon {
        font-size: 45px;
    }

</style>

<div class="container mt-5">

    <!-- Header -->
    <div class="text-center mb-5">

        <h1 class="display-3 fw-bold text-primary"> InternFlow </h1>

        <p class="lead text-secondary"> Task, project and team management system </p>

    </div>

    <!-- Istatislikler -->
    <div class="row mb-5">

        <div class="col-md-3 mb-3">
            <div class="card bg-primary text-white shadow border-0 rounded-4">

                <div class="card-body text-center">

                    <h5>Total Users</h5>
                    <h2 class="fw-bold">@ViewBag.TotalUsers</h2>

                </div>

            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card bg-success text-white shadow border-0 rounded-4">

                <div class="card-body text-center">

                    <h5>Total Projects</h5>
                    <h2 class="fw-bold">@ViewBag.TotalProjects</h2>

                </div>

            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card bg-warning text-dark shadow border-0 rounded-4">

                <div class="card-body text-center">

                    <h5>Active Tasks</h5>
                    <h2 class="fw-bold">@ViewBag.ActiveTasks</h2>

                </div>

            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card bg-danger text-white shadow border-0 rounded-4">

                <div class="card-body text-center">

                    <h5>Completed Tasks</h5>
                    <h2 class="fw-bold">
                        @(ViewBag.CompletedTasks ?? 0)
                    </h2>

                </div>

            </div>
        </div>

    </div>

    <!-- Ana Modüller -->
    <div class="row g-4">

        <!-- Kullanıcılar -->
        <div class="col-md-3">

            <div class="card dashboard-card shadow-lg border-0 rounded-4 h-100">

                <div class="card-body text-center p-4">

                    <div class="dashboard-icon mb-3">👤</div>

                    <h3 class="fw-bold">Users</h3>

                    <p class="text-muted">Manage users and interns within the system.</p>

                    <button onclick="location.href='@Url.Action("Index", "User")'"
                            class="btn btn-primary w-100 py-2 rounded-pill">
                        Users Panel
                    </button>

                </div>

            </div>

        </div>

        <!-- Projeler -->
        <div class="col-md-3">

            <div class="card dashboard-card shadow-lg border-0 rounded-4 h-100">

                <div class="card-body text-center p-4">

                    <div class="dashboard-icon mb-3">📁</div>

                    <h3 class="fw-bold">Projects</h3>

                    <p class="text-muted">Create projects and track project progress.</p>

                    <button onclick="location.href='@Url.Action("Index", "Project")'"
                            class="btn btn-success w-100 py-2 rounded-pill">
                        Project Panel
                    </button>

                </div>

            </div>

        </div>

        <!-- Görevler -->
        <div class="col-md-3">

            <div class="card dashboard-card shadow-lg border-0 rounded-4 h-100">

                <div class="card-body text-center p-4">

                    <div class="dashboard-icon mb-3">✅</div>

                    <h3 class="fw-bold">Tasks</h3>

                    <p class="text-muted">Manage task statuses, priorities, and assignments.</p>

                    <button onclick="location.href='@Url.Action("Index", "Task")'"
                            class="btn btn-warning text-white w-100 py-2 rounded-pill">
                        Task Panel
                    </button>

                </div>

            </div>

        </div>

        <!-- Üyeler -->
        <div class="col-md-3">

            <div class="card dashboard-card shadow-lg border-0 rounded-4 h-100">

                <div class="card-body text-center p-4">

                    <div class="dashboard-icon mb-3">👥</div>

                    <h3 class="fw-bold">Dashboard</h3>

                    <p class="text-muted">Monitor task statuses, priorities, and user workloads.</p>

                    <button onclick="location.href='@Url.Action("Index", "ProjectMember")'"
                            class="btn btn-dark w-100 py-2 rounded-pill">
                        Dashboard Panel
                    </button>

                </div>

            </div>

        </div>

    </div>

</div>