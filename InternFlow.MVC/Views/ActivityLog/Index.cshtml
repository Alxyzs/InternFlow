@{
}
@model List<InternFlow.EL.DBContextModels.ActivityLog>

@{
    ViewData["Title"] = "Activity Logs";
}

<div class="container mt-5">

    <h2 class="mb-4">📜 Activity Logs</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">Henüz aktivite yok.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Date</th>
                        <th>Action</th>
                        <th>Detail</th>
                        <th>Task</th>
                        <th>User</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model.OrderByDescending(l => l.CreatedAt))
                    {
                        <tr>
                            <td>@log.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <span class="badge bg-primary">@log.Action</span>
                            </td>
                            <td>@log.Detail</td>
                            <td>@log.TaskItemId</td>
                            <td>@log.UserId</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>